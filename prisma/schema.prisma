generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ImportBatch {
  id          String   @id @default(cuid())
  fileName    String?
  contentHash String
  rawMarkdown String
  createdAt   DateTime @default(now())
  tasks       Task[]
}

enum SyncStatus {
  pending
  synced
  failed
}

model Task {
  id                   String      @id @default(cuid())
  ticketNumber         Int
  title                String
  userStory            String      @default("")
  description          String      @default("")
  acceptanceCriteria   String      @default("")
  estimate             String      @default("")
  priority             String      @default("")
  importBatchId        String
  importBatch          ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  basecampCardId       String?
  basecampColumnListId String?
  syncStatus           SyncStatus  @default(pending)
  lastSyncedAt         DateTime?
  lastSyncError        String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@unique([importBatchId, ticketNumber])
  @@index([syncStatus])
}

model BasecampConnection {
  id               String   @id @default("default")
  accessTokenEnc   String
  refreshTokenEnc  String
  expiresAt        DateTime
  accountId        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
