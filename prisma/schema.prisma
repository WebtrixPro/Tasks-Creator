generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// IMPORT BATCH - Original model for bulk imports
// ============================================
model ImportBatch {
  id          String   @id @default(cuid())
  fileName    String?
  contentHash String
  rawMarkdown String
  createdAt   DateTime @default(now())
  tasks       Task[]
}

// ============================================
// SYNC STATUS ENUM
// ============================================
enum SyncStatus {
  pending
  synced
  failed
  local_only
}

// ============================================
// PROJECT - Local-first with optional Basecamp link
// ============================================
model Project {
  id                String    @id @default(cuid())
  name              String
  description       String?
  color             String?   @default("#6366f1")
  basecampProjectId String?   @unique
  isArchived        Boolean   @default(false)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tasks             Task[]
  members           ProjectMember[]
  columns           Column[]
  activities        Activity[]

  @@index([isArchived, deletedAt])
  @@index([basecampProjectId])
}

// ============================================
// TEAM MEMBER - User/assignee management
// ============================================
model TeamMember {
  id               String    @id @default(cuid())
  name             String
  email            String?   @unique
  avatarUrl        String?
  basecampPersonId String?   @unique
  role             String    @default("member")
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignedTasks      Task[]         @relation("TaskAssignee")
  createdTasks       Task[]         @relation("TaskCreator")
  projectMemberships ProjectMember[]
  activities         Activity[]
  comments           TaskComment[]

  @@index([email])
  @@index([basecampPersonId])
}

// ============================================
// PROJECT MEMBER - Many-to-many project membership
// ============================================
model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  memberId  String
  role      String     @default("member")
  joinedAt  DateTime   @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([projectId, memberId])
  @@index([projectId])
  @@index([memberId])
}

// ============================================
// COLUMN - Kanban columns for projects
// ============================================
model Column {
  id        String    @id @default(cuid())
  name      String
  projectId String
  position  Int       @default(0)
  color     String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([projectId, position])
}

// ============================================
// TASK - Enhanced with relations and soft delete
// ============================================
model Task {
  id                   String      @id @default(cuid())
  ticketNumber         Int
  title                String
  userStory            String      @default("")
  description          String      @default("")
  acceptanceCriteria   String      @default("")
  estimate             String      @default("")
  priority             String      @default("medium")
  status               String      @default("pending")
  position             Int         @default(0)
  startDate            DateTime?
  endDate              DateTime?
  dueDate              DateTime?
  
  // Relations
  importBatchId        String?
  importBatch          ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  projectId            String?
  project              Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  columnId             String?
  column               Column?      @relation(fields: [columnId], references: [id], onDelete: SetNull)
  assigneeId           String?
  assignee             TeamMember?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId            String?
  creator              TeamMember?  @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  
  // Basecamp sync
  basecampCardId       String?
  basecampColumnListId String?
  syncStatus           SyncStatus   @default(pending)
  lastSyncedAt         DateTime?
  lastSyncError        String?
  
  // Soft delete
  deletedAt            DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  
  // Relations
  comments             TaskComment[]

  @@unique([importBatchId, ticketNumber])
  @@index([syncStatus])
  @@index([projectId, status])
  @@index([assigneeId])
  @@index([columnId, position])
  @@index([deletedAt])
  @@index([dueDate])
}

// ============================================
// TASK COMMENT - Comments on tasks
// ============================================
model TaskComment {
  id        String     @id @default(cuid())
  content   String
  taskId    String
  authorId  String?
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  task      Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    TeamMember? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

// ============================================
// ACTIVITY - Full audit trail
// ============================================
model Activity {
  id         String     @id @default(cuid())
  action     String
  entityType String
  entityId   String
  projectId  String?
  actorId    String?
  metadata   Json?
  createdAt  DateTime   @default(now())

  project    Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actor      TeamMember? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([projectId, createdAt])
  @@index([actorId])
  @@index([createdAt])
}

// ============================================
// BASECAMP CONNECTION - OAuth tokens
// ============================================
model BasecampConnection {
  id              String   @id @default("default")
  accessTokenEnc  String
  refreshTokenEnc String
  expiresAt       DateTime
  accountId       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
